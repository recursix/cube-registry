<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>CUBE Registry — Benchmark Catalog</title>
  <meta name="description" content="The official catalog of CUBE-compliant AI benchmarks. Discover, filter, and install benchmarks with a single pip install." />
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    [x-cloak] { display: none !important; }
    .line-clamp-3 {
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .card-hover { transition: box-shadow 0.15s ease, transform 0.15s ease; }
    .card-hover:hover { box-shadow: 0 8px 30px rgba(0,0,0,0.12); transform: translateY(-2px); }
  </style>
</head>
<body class="bg-gray-50 text-gray-900 min-h-screen">

<!-- ── Header ────────────────────────────────────────────────────────────── -->
<header class="bg-white border-b border-gray-200 sticky top-0 z-30 shadow-sm">
  <div class="max-w-7xl mx-auto px-4 py-3 flex items-center justify-between">
    <div class="flex items-center gap-3">
      <span class="text-2xl font-bold text-indigo-700 tracking-tight">CUBE Registry</span>
      <span class="text-sm bg-indigo-50 text-indigo-600 px-2 py-0.5 rounded font-medium">{{ total }} benchmarks</span>
    </div>
    <nav class="flex gap-4 text-sm text-gray-600">
      <a href="https://github.com/The-AI-Alliance/cube-standard" class="hover:text-indigo-700" target="_blank" rel="noopener">Spec</a>
      <a href="https://github.com/The-AI-Alliance/cube-registry" class="hover:text-indigo-700" target="_blank" rel="noopener">GitHub</a>
      <a href="https://github.com/The-AI-Alliance/cube-registry/blob/main/README.md#submitting-a-benchmark" class="bg-indigo-600 text-white px-3 py-1 rounded hover:bg-indigo-700 font-medium" target="_blank" rel="noopener">Submit benchmark</a>
    </nav>
  </div>
</header>

<!-- ── Hero ──────────────────────────────────────────────────────────────── -->
<section class="bg-gradient-to-br from-indigo-900 via-indigo-800 to-indigo-700 text-white py-14 px-4">
  <div class="max-w-3xl mx-auto text-center">
    <h1 class="text-4xl font-extrabold mb-3">CUBE-Compliant Benchmark Catalog</h1>
    <p class="text-lg text-indigo-200 mb-6">
      Any CUBE-compliant evaluation platform can discover and run these benchmarks without custom integration.
      One YAML file per benchmark. Fully automated CI.
    </p>
    <div class="flex items-center justify-center gap-3 flex-wrap">
      <code class="bg-indigo-950/60 px-4 py-2 rounded-lg text-indigo-100 font-mono text-sm">pip install &lt;package&gt;</code>
      <span class="text-indigo-300 text-sm">→ ready to evaluate</span>
    </div>
  </div>
</section>

<!-- ── Legal disclaimer ──────────────────────────────────────────────────── -->
<div class="bg-yellow-50 border-b border-yellow-200">
  <div class="max-w-7xl mx-auto px-4 py-2 text-xs text-yellow-800">
    <strong>License disclaimer:</strong> License information in this registry is <strong>self-reported</strong> by cube developers and has not been verified by the AI Alliance.
    Always consult <code>benchmark_license.source_url</code> and the original benchmark authors for authoritative terms.
  </div>
</div>

<!-- ── Filter bar ────────────────────────────────────────────────────────── -->
<div class="bg-white border-b border-gray-200 sticky top-14 z-20 shadow-sm" id="filter-bar">
  <div class="max-w-7xl mx-auto px-4 py-3 flex flex-wrap gap-3 items-center">
    <!-- Search -->
    <input
      type="search"
      id="search-input"
      placeholder="Search benchmarks..."
      class="border border-gray-300 rounded-lg px-3 py-1.5 text-sm w-64 focus:outline-none focus:ring-2 focus:ring-indigo-400"
      oninput="filterCards()"
    />

    <!-- Tag filter -->
    <div class="flex flex-wrap gap-1.5">
      {% for tag in all_tags %}
      <button
        class="filter-tag text-xs px-2.5 py-1 rounded-full border border-gray-300 text-gray-600 hover:bg-indigo-50 hover:border-indigo-400 hover:text-indigo-700 transition-colors"
        data-tag="{{ tag }}"
        onclick="toggleTagFilter(this)"
      >{{ tag }}</button>
      {% endfor %}
    </div>

    <!-- Feature filter -->
    {% if all_features %}
    <div class="flex flex-wrap gap-1.5 border-l border-gray-200 pl-3">
      {% for feat in all_features %}
      <button
        class="filter-feature text-xs px-2.5 py-1 rounded-full border border-gray-300 text-gray-600 hover:bg-purple-50 hover:border-purple-400 hover:text-purple-700 transition-colors"
        data-feature="{{ feat }}"
        onclick="toggleFeatureFilter(this)"
      >{{ feat }}</button>
      {% endfor %}
    </div>
    {% endif %}

    <!-- Status filter -->
    <div class="flex gap-1.5 border-l border-gray-200 pl-3 ml-auto">
      <button class="filter-status text-xs px-2.5 py-1 rounded-full border border-green-300 text-green-700 hover:bg-green-50" data-status="active" onclick="toggleStatusFilter(this)">Active</button>
      <button class="filter-status text-xs px-2.5 py-1 rounded-full border border-yellow-300 text-yellow-700 hover:bg-yellow-50" data-status="degraded" onclick="toggleStatusFilter(this)">Degraded</button>
    </div>

    <button onclick="clearFilters()" class="text-xs text-gray-400 hover:text-gray-600 underline ml-1">Clear filters</button>
  </div>
</div>

<!-- ── Card grid ─────────────────────────────────────────────────────────── -->
<main class="max-w-7xl mx-auto px-4 py-8">
  <div id="card-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5">

    {% for entry in entries %}
    <article
      class="bg-white rounded-xl border border-gray-200 card-hover flex flex-col overflow-hidden"
      data-id="{{ entry.id }}"
      data-tags="{{ (entry.tags or []) | join(' ') }}"
      data-features="{{ (entry.features_list or []) | join(' ') }}"
      data-infra="{{ (entry.supported_infra or []) | join(' ') }}"
      data-status="{{ entry.status }}"
      data-name="{{ entry.name | lower }}"
      data-description="{{ (entry.description or '') | lower }}"
    >
      <!-- Card header -->
      <div class="p-4 flex-1 flex flex-col gap-2">
        <!-- Status + task count -->
        <div class="flex items-center justify-between gap-2">
          <span class="inline-flex items-center text-xs font-medium px-2 py-0.5 rounded-full {{ entry.status_badge.bg }} {{ entry.status_badge.text }}">
            {{ entry.status_badge.label }}
          </span>
          {% if entry.task_count is not none %}
          <span class="text-xs text-gray-400">{{ entry.task_count }} tasks</span>
          {% endif %}
        </div>

        <!-- Name -->
        <h2 class="font-bold text-gray-900 text-base leading-snug">
          <a href="{{ entry.id }}/" class="hover:text-indigo-700">{{ entry.name }}</a>
        </h2>

        <!-- Description -->
        <p class="text-sm text-gray-500 line-clamp-3 flex-1">{{ entry.description_short }}</p>

        <!-- Tags -->
        {% if entry.tag_chips %}
        <div class="flex flex-wrap gap-1 mt-1">
          {% for chip in entry.tag_chips %}
          <span class="text-xs px-2 py-0.5 rounded-full font-medium {{ chip.cls }}">{{ chip.label }}</span>
          {% endfor %}
        </div>
        {% endif %}

        <!-- Feature flags (compact) -->
        {% if entry.features_list %}
        <div class="flex flex-wrap gap-1">
          {% for feat in entry.features_list %}
          <span class="text-xs px-1.5 py-0.5 rounded bg-purple-50 text-purple-700 font-mono">{{ feat }}</span>
          {% endfor %}
        </div>
        {% endif %}
      </div>

      <!-- Card footer: links -->
      <div class="border-t border-gray-100 px-4 py-2.5 flex items-center gap-3 text-xs text-gray-500">
        <a href="{{ entry.id }}/" class="hover:text-indigo-700 font-medium text-indigo-600">Details →</a>
        {% if entry.paper %}
        <a href="{{ entry.paper }}" class="hover:text-gray-800" target="_blank" rel="noopener">Paper</a>
        {% endif %}
        {% if entry.getting_started_url %}
        <a href="{{ entry.getting_started_url }}" class="hover:text-gray-800" target="_blank" rel="noopener">Docs</a>
        {% endif %}
        <a href="https://pypi.org/project/{{ entry.package }}/" class="ml-auto hover:text-gray-800" target="_blank" rel="noopener">PyPI</a>
      </div>
    </article>
    {% else %}
    <div class="col-span-full text-center py-20 text-gray-400">
      <p class="text-2xl mb-2">No benchmarks yet</p>
      <p class="text-sm">Be the first to <a href="https://github.com/The-AI-Alliance/cube-registry/blob/main/README.md#submitting-a-benchmark" class="text-indigo-600 underline">submit one</a>.</p>
    </div>
    {% endfor %}
  </div>

  <!-- No results message -->
  <div id="no-results" class="hidden text-center py-20 text-gray-400">
    <p class="text-xl mb-2">No benchmarks match your filters.</p>
    <button onclick="clearFilters()" class="text-indigo-600 underline text-sm">Clear filters</button>
  </div>
</main>

<!-- ── Footer ────────────────────────────────────────────────────────────── -->
<footer class="border-t border-gray-200 bg-white mt-8 py-6 text-center text-xs text-gray-400">
  <p>
    CUBE Registry — <a href="https://github.com/The-AI-Alliance/cube-registry" class="underline">GitHub</a> ·
    <a href="https://github.com/The-AI-Alliance/cube-standard" class="underline">CUBE Standard</a> ·
    Generated {{ generated_at }}
  </p>
  <p class="mt-1">License information is self-reported. The AI Alliance makes no warranty as to its accuracy.</p>
</footer>

<script>
  // ── Filter state ───────────────────────────────────────────────────────────
  const activeFilters = { tags: new Set(), features: new Set(), statuses: new Set() };

  function toggleTagFilter(btn) {
    const tag = btn.dataset.tag;
    if (activeFilters.tags.has(tag)) {
      activeFilters.tags.delete(tag);
      btn.classList.remove('bg-indigo-100', 'border-indigo-500', 'text-indigo-800');
    } else {
      activeFilters.tags.add(tag);
      btn.classList.add('bg-indigo-100', 'border-indigo-500', 'text-indigo-800');
    }
    applyFilters();
  }

  function toggleFeatureFilter(btn) {
    const feat = btn.dataset.feature;
    if (activeFilters.features.has(feat)) {
      activeFilters.features.delete(feat);
      btn.classList.remove('bg-purple-100', 'border-purple-500', 'text-purple-800');
    } else {
      activeFilters.features.add(feat);
      btn.classList.add('bg-purple-100', 'border-purple-500', 'text-purple-800');
    }
    applyFilters();
  }

  function toggleStatusFilter(btn) {
    const status = btn.dataset.status;
    if (activeFilters.statuses.has(status)) {
      activeFilters.statuses.delete(status);
      btn.classList.remove('ring-2', 'ring-offset-1');
    } else {
      activeFilters.statuses.add(status);
      btn.classList.add('ring-2', 'ring-offset-1');
    }
    applyFilters();
  }

  function filterCards() { applyFilters(); }

  function applyFilters() {
    const query = (document.getElementById('search-input').value || '').toLowerCase().trim();
    const cards = document.querySelectorAll('#card-grid article');
    let visible = 0;

    cards.forEach(card => {
      const tags = card.dataset.tags || '';
      const features = card.dataset.features || '';
      const status = card.dataset.status || '';
      const name = card.dataset.name || '';
      const description = card.dataset.description || '';
      const id = card.dataset.id || '';

      // Search filter
      const matchSearch = !query ||
        name.includes(query) ||
        description.includes(query) ||
        id.includes(query) ||
        tags.includes(query);

      // Tag filter (AND logic — all selected tags must be present)
      const matchTags = activeFilters.tags.size === 0 ||
        [...activeFilters.tags].every(t => tags.split(' ').includes(t));

      // Feature filter (AND logic)
      const matchFeatures = activeFilters.features.size === 0 ||
        [...activeFilters.features].every(f => features.split(' ').includes(f));

      // Status filter (OR logic)
      const matchStatus = activeFilters.statuses.size === 0 ||
        activeFilters.statuses.has(status);

      const show = matchSearch && matchTags && matchFeatures && matchStatus;
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });

    document.getElementById('no-results').style.display = visible === 0 ? '' : 'none';
  }

  function clearFilters() {
    activeFilters.tags.clear();
    activeFilters.features.clear();
    activeFilters.statuses.clear();
    document.getElementById('search-input').value = '';
    document.querySelectorAll('.filter-tag, .filter-feature, .filter-status').forEach(btn => {
      btn.classList.remove(
        'bg-indigo-100', 'border-indigo-500', 'text-indigo-800',
        'bg-purple-100', 'border-purple-500', 'text-purple-800',
        'ring-2', 'ring-offset-1'
      );
    });
    applyFilters();
  }
</script>
</body>
</html>
